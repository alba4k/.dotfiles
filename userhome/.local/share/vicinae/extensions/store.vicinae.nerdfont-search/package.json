      "mode": "view"
    }
  ],
  "preferences": [],
  "scripts": {
    "build": "vici build",
    "dev": "vici develop",
    "format": "biome format --write src",
    "lint": "vici lint",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@vicinae/api": "^0.19.9",
    "fuse.js": "^7.1.0",
    "zod": "^4.3.6"
