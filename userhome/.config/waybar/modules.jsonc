{
       "modules-left": [
           "custom/launcher",
           "cpu",
           "temperature",
           "memory",
           "network",
           "bluetooth"
       ],
       "modules-center": [
           "hyprland/workspaces",
           "hyprland/window"
       ],

       "modules-right": [
           "battery",
           "custom/media-bw",
           "custom/media-pp",
           "custom/media-fw",
           "cava",
           "pulseaudio",
           "custom/greentoyellow",
           "backlight",
           "idle_inhibitor",
           "clock",
           "tray"
       ],

    "custom/launcher": {
        "format": "ïچ™ ",
        "interval": "once",

        "on-click": "rofi -show drun",
        "on-click-right": "rofi -show run",
        "on-click-middle": "pidof wlogout || wlogout",

        "tooltip": false
    },

    "cpu": {
        "interval": 10,
        "format": "ï’¼ {usage}%",
        "format-alt": "{min_frequency} GHz - {max_frequency} GHz"
    },

    "temperature": {
        "thermal-zone": 6,
        "format": "{icon} {temperatureC}آ°C",
        "format-icons": ["ï‹‹", "ï‹ٹ", "ï‹‰", "ï‹ˆ", "ï‹‡"],
        "tooltip": false
    },

    "memory": {
        "interval": 15,
        "format": "î‰¦ {percentage}%",
        "max-length": 10,
        "tooltip": true,
        "tooltip-format": "î‰¦ {used:0.1f} GB/{total:0.1f} GB ({percentage}%)"
    },
    
    "network": {
        "interval": 200,
        "format-wifi": "ï‡«  {essid}",
        "format-ethernet": "َ±ک– Ethernet",
        "format-linked": "َ±ک– {ifname} (No IP)",
        "format-disabled": "َ°–ھ Offline",
        "format-disconnected": "َ°–ھ Offline",
        "tooltip-format-wifi": "َ±ک– {signalStrength}% َ°©© {frequency} GHz - {ipaddr}",
        "tooltip-format-ethernet": "َ°‘© {bandwidthTotalBytes} B/s - {ipaddr}",
        "tooltip-format-disconnected": "Nessuna rete",
        "tooltip-format-disabled": "WiFi Disabilitato",

        "on-click": "rfkill toggle wifi",
        "on-click-right": "hypr-network-manager",
        "on-click-middle": "pidof nm-connection-editor || nm-connection-editor && killall nm-connection-editor"
    },

    "bluetooth": {
	    "format": "َ°‚¯",
	    "format-disabled": "َ°‚² Spento",
	    "format-no-controller": "َ°‚² Spento",
	    "format-off": "َ°‚² Spento",
	    "format-connected": "َ°‚± ({num_connections}) {device_alias}",
	    "tooltip-format-enumerate-connected": "َ°‚± {device_alias}",
	    "tooltip-format-enumerate-connected-battery": "َ°‚± {device_alias} (َ°پ¹ {device_battery_percentage}%)",
        "max-length": 20,

        "on-click": "rfkill toggle bluetooth",
        "on-click-right": "pidof blueman-manager || blueman-manager && killall blueman-manager",
        "on-click-middle": "~/.local/bin/buds"
    },

    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "ï„، ",
            "2": "ï‰© ",
            "3": "ïپµ ",
            "4": "ï…› ",
            "5": "ï€پ ",
            "6": "ï„› ",
            "7": "ï€½ ",
            "default": "ï„‘ "
        },

        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1"
    },

    "hyprland/window": {
        "format": "ï…‚ {title}",
        "icon": false,
        "separate-outputs": true,
        // I now consider myself to be a regex god
        "rewrite": {
            "ï…‚ \\([0-9]*\\ (.*)": "ï…‚ $1", // Telegram Desktop
            "ï…‚ â€¢ (.*)": "ï…‚ $1", // Discord
            "ï…‚ (\\([0-9]*\\) )?(.*) â€“ .*": "ï…‚ $2", // Telegram Desktop
            "(.*) â€” Mozilla Firefox": "$1",
            "(.*/.*): .*": "$1", // GitHub repositories
            "ï…‚ Prism Launcher.*": "ï…‚ Prism Launcher",
            "(.*) â€” Prism Launcher.*": "Prism Launcher ($1)",
            "ï…‚ Cemu.*FPS: ([0-9]+\\.[0-9]+).*TitleId.*\\] (.*) \\[.*": "ï…‚ Cemu - $2 ($1 FPS)",
            "^(.{100}).{3}.*": "$1..",
            "ï…‚ ": "ï…‚ Desktop"
        },
        "tooltip": false,

        // "on-click-right": "hyprctl dispatch fullscreen",
        "on-click-right": "sleep .3 && ~/.config/hypr/scripts/resize.sh",
        "on-click-middle": "hyprctl dispatch killactive"
    },

    "battery": {
        "interval": 5,

        "format": "{icon} {capacity}%",
        //"format-icons": ["ï‰„ ", "ï‰ƒ ", "ï‰‚ ", "ï‰پ ", "ï‰€ "],
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "format-charging": "{icon} {capacity}% ïƒ§",
        "format-plugged": "{icon} {capacity}% َ°ڑ¥",
        "tooltip-format": "{power}W - {timeTo}",

        "states": {
            "full": 100,
            "great": 97,
            "good": 85,
            "ok": 50,
            "warning": 30,
            "low": 20,
            "critical": 10
        },

        "on-click": "pkexec ~/.local/bin/powersave && notify-send -r 1234 -t 2000 -a Prestazioni -u low -i battery 'Risparmio energetico attivato!'",
        "on-click-right": "pkexec ~/.local/bin/balanced && notify-send -r 1234 -t 2000 -a Prestazioni -u low -i battery 'Modalitأ  bilanciata attivata!'",
        "on-click-middle": "pkexec ~/.local/bin/performance && notify-send -r 1234 -t 2000 -a Prestazioni -u low -i battery 'Modalitأ  prestazioni attivata!'"
    },

    "custom/media-bw": {
        "interval": 1,
        "format": "ïپˆ",
        "exec": "~/.config/waybar/scripts/audio-back-skip.sh 2>/dev/null",

        "on-click": "playerctl previous",
        "on-click-right": "~/.config/rofi/music/music",
        "on-click-middle": "~/.config/rofi/music/music",

        "return-type": "json"
    },
    "custom/media-pp": {
        "interval": 1,
        "format": "{}",
        "exec": "~/.config/waybar/scripts/audio-play-pause.sh 2>/dev/null",

        "on-click": "playerctl play-pause",
        "on-click-right": "~/.config/rofi/music/music",
        "on-click-middle": "~/.config/rofi/music/music",

    
        "return-type": "json"
    },
    "custom/media-fw": {
        "interval": 1,
        "format": "ïپ‘",
        "exec": "~/.config/waybar/scripts/audio-back-skip.sh 2>/dev/null",

        "on-click": "playerctl next",
        "on-click-right": "~/.config/rofi/music/music",
        "on-click-middle": "~/.config/rofi/music/music",

        "return-type": "json"
    },
    "mpris": {
        "format": "ï…‚ {player_icon}  {title} â€” {artist}",
        "format-paused": "ï…‚ {player_icon}  <i>{title} â€” {artist}</i>",
        "tooltip-format": "{player} â€” {position}/{length}",
        "player-icons": {
            "default": "ï€پ",
            "spotify": "ï†¼",
            "firefox": "ï‰©",
            "kdeconnect": "ï„‹"
        },
        "status-icons": {
            "paused": "âڈ¸"
	    },
	    "ignored-players": ["kdeconnect"]
    },
    "cava": {
        "framerate": 20,
        "autosens": 1,
        "sensitivity":2,
        "bars": 6,
        "lower_cutoff_freq": 50,
        "higher_cutoff_freq": 10000,
        "method": "pipewire",
        "source": "auto",
        "stereo": false,
        "sleep_timer": 1,
        "hide_on_silence": true,
        "reverse": false,
        "bar_delimiter": 0,
        "monstercat": false,
        "waves": false,
        "noise_reduction": 0.77,
        "input_delay": 2,
        "format-icons" : ["â–پ", "â–‚", "â–ƒ", "â–„", "â–…", "â–†", "â–‡", "â–ˆ" ],
        "actions": {
                   "on-click-right": "mode"
                   }
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "î»¨ ({volume}%)",
        "on-click": "pavucontrol -t 3",
        "interval": 1,
        "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-middle": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ -1%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ +1%",
        "tooltip-format": "{desc}",
        "format-icons": {
            "headphone": "ï€¥",
            "hands-free": "ï€¥",
            "headset": "ï€¥",
            //"speaker": "َ°“ƒ",
            "hifi": "َ°“ƒ",
            "hdmi": "َ°½ں",
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": ["ï€¦", "ï€§", "ï€¨"]
        }
    },

    "backlight": {
        "interval": 1,
        "format": "{icon} {percent}%",
        "scroll-step": -0.3,
        "format-icons": ["َ°ƒ‍", "َ°ƒ‌", "َ°ƒں", "َ°ƒ "],

        "on-click": "~/.config/waybar/scripts/hyprsunset.sh",

        "tooltip": false
    },

    "clock": {
        "format": "ïگ؛ {:%H:%M}",
        "format-alt": "ï„³ {:%a %d %b}",
        "locale": "it_CH.UTF-8",
        "tooltip-format": "<tt><big>{calendar}</big></tt>",
        "calendar": {
                    "mode"          : "month",
                    "weeks-pos"     : "left",
                    "on-scroll"     : 1,
                    "format": {
                              "months":     "<span color='#ffead3'><b>{}</b></span>",
                              "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                              "weeks":      "<span color='#99ffdd'><b>{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                              }
                    }
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {"activated": "î©° ", "deactivated": "î«§ "}
    },

    "tray": {
        "icon-size": 15,
        "show-passive-items": true,
        "spacing": 5
    },

    // decoration //

    "custom/greentored": {
        "interval": "once",
        "tooltip": false,
        "format": "î‚°"
    },

    "custom/redtoyellow": {
        "interval": "once",
        "tooltip": false,
        "format": "î‚°"
    },

    "custom/greentoblue": {
        "interval": "once",
        "tooltip": false,
        "format": "î‚°"
    },

    "custom/bluetogreen": {
        "interval": "once",
        "tooltip": false,
        "format": "î‚²"
    },

    // backlight disappears when only using an external monitor
    "custom/greentoyellow": {
        "interval": 5,
        "return-type": "json",
        
        "exec": "~/.config/waybar/scripts/greentoyellow.sh",

        "format": "{}"
    }
}

