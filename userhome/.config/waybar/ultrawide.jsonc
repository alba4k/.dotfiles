{
    "name": "ultrawide",
    "layer": "bottom",
    "position": "top",
    "mod": "dock",
    "height": 33,
    "exclusive": true,
    "passthrough": false,
    "fixed-center": true,

    "modules-left": [
        "custom/launcher",
        "cpu",
        "temperature",
        "memory",
        "network",
        "bluetooth"
    ],
    "modules-center": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-right": [
        "battery",
        "custom/media-bw",
        "custom/media-pp",
        "custom/media-fw",
        "mpris",
        "cava",
        "pulseaudio",
        "custom/greentoyellow",
        "custom/ext_backlight",
        "idle_inhibitor",
        "clock",
        "tray"
    ],

    "include": ["~/.config/waybar/modules.jsonc"],

    "bluetooth": {
        "max-length": 40
    },

    "cava": {
        "bars": 16,
        "stereo": true
    }
}

